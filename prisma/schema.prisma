generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id           String   @id @default(uuid())
  cycleId      String
  brandId      String
  status       String
  title        String
  content      String
  sourceUrl    String?
  sourceTitle  String?
  reviewResult  String?
  wpPostId      String?
  featuredImage String?
  images        String?  // JSON: string[] of additional image URLs (index 1+)
  revisionCount Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Insight {
  id             String   @id @default(uuid())
  targetAgent    String
  suggestionText String
  status         String   @default("Pending")
  createdAt      DateTime @default(now())
}

model SeoDirective {
  id         String   @id @default(uuid())
  cycleId    String   @unique
  directives String   // JSON: InvestigatorDirective[]
  createdAt  DateTime @default(now())
}

model Settings {
  id              String  @id @default("singleton")
  scrapeFrequency String  @default("4h")
  requireReview   Boolean @default(false)
  isLive          Boolean @default(false)
  targetNiche     String  @default("Indonesian property real estate")
  nicheA          String  @default("")
  nicheB          String  @default("")
  nicheC          String  @default("")
  nicheD          String  @default("")
  nicheE          String  @default("")
  toneA           String  @default("Anime: energetic, otaku-friendly, pop-culture savvy")
  toneB           String  @default("Toys: playful, family-friendly, collector-focused")
  toneC           String  @default("Infotainment: engaging, informative, trending-topic driven")
  toneD           String  @default("Game: hype-driven, gamer-voice, esports-aware")
  toneE           String  @default("Comic: fan-focused, narrative-driven, superhero & manga aware")
  rssSourcesA     String  @default("")
  rssSourcesB     String  @default("")
  rssSourcesC     String  @default("")
  rssSourcesD     String  @default("")
  rssSourcesE     String  @default("")
  imageCountA     Int     @default(1)
  imageCountB     Int     @default(1)
  imageCountC     Int     @default(1)
  imageCountD     Int     @default(1)
  imageCountE     Int     @default(1)
  seoDedupeHours               Int     @default(24)
  seoShortTail                 Int     @default(2)
  seoEvergreen                 Int     @default(1)
  investigatorDedupeHours      Int     @default(24)
  investigatorMaxSameFranchise Int     @default(1)
}
